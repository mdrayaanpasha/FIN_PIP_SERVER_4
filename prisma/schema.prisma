generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//ohlvc data
model OhlvcData{
  ticker String @unique
  timestamp DateTime
  open Float
  high Float
  low Float
  volume Float
  close Float 
}

model Indicators{
  ticker String @unique
  timestamp DateTime
  rsi Float
  ema Float
  sma Float
}

